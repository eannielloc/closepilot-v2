# App
NEXT_PUBLIC_APP_URL="https://closepilot-v2.vercel.app"

# AI — Anthropic Claude (used for PDF contract parsing). Falls back to mock if unset.
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-4-5-20250929"

# Email — SMTP (Gmail app password works). Email sending is no-op if unset.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your.address@gmail.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"
SMTP_FROM="ClosePilot <your.address@gmail.com>"

# Auth — secret used to sign session cookies. Generate with: openssl rand -hex 32
AUTH_SECRET="change-me-to-32-random-bytes"
